# FastAPI server
HOST=0.0.0.0
PORT=8000

# LLM provider settings
LLM_PROVIDER=open_source
LLM_MODEL=mistral
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=

# Run state persistence
DATABASE_URL=
RUN_STATE_SQLITE_PATH=data/run_state.db
RUN_STAGE_MAX_ATTEMPTS=3

# Supabase observability
OBSERVABILITY_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=observability
SUPABASE_LOGS_TABLE=app_trace_events
SUPABASE_HTTP_TIMEOUT=15
SUPABASE_ENABLE_LOG_WRITE=false
