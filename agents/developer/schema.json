{
  "name": "developer",
  "description": "Genera código a partir del plan del planner.",
  "input": {
    "type": "object",
    "properties": {
      "plan": { "type": "object" }
    },
    "required": ["plan"]
  },
  "output": {
    "type": "object",
    "properties": {
      "files": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "content": { "type": "string" }
          },
          "required": ["path", "content"]
        }
      }
    },
    "required": ["files"]
  }
}
